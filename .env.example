# FishSpotter Environment Variables
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=your_postgresql_connection_string

# Google AI API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here
# Alternative naming for Google AI API (optional, for backward compatibility)
GOOGLE_AI_API_KEY=your_google_gemini_api_key_here

# Session Management
# Generate a secure random string for production: https://randomkeygen.com/
SESSION_SECRET=your_secure_session_secret_change_this_in_production

# Server Configuration
NODE_ENV=development
PORT=5000

# Security Notes:
# - Never commit your actual .env file to version control
# - Use a strong, unique SESSION_SECRET in production
# - Restrict your Google AI API key to specific domains/IPs in production
# - Regularly rotate your API keys for security
